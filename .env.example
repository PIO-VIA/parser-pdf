# Application
APP_NAME=MedicalBackend
APP_VERSION=1.0.0
APP_ENV=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DB_USER=meduser
DB_PASSWORD=medpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medical_db

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@clinique.com
SMTP_PASSWORD=dummy_password
EMAIL_FROM=noreply@clinique.com
EMAIL_FROM_NAME=Clinique Pneumologie

# Frontend URL (pour liens reset password)
FRONTEND_URL=https://your-frontend.com

# CORS
CORS_ORIGINS=["http://localhost:3000","https://your-frontend.com"]
